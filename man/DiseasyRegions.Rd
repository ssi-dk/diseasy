    region = c("north", "north", "south", "south", "east", "east"),
    age_group = rep(c("0-17", "18+"), times = 3),
    population = c(100, 300, 80, 220, 60, 140)
  )

  # Adjacency is a long-form representation of connectedness.
  adjacency <- data.frame(
